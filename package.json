{
  "name": "@getdial/cli",
  "version": "0.15.3",
  "description": "Dial CLI — install, sign up, and run the local listen service.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GetDial-AI/cli.git"
  },
  "homepage": "https://github.com/GetDial-AI/cli#readme",
  "bugs": {
    "url": "https://github.com/GetDial-AI/cli/issues"
  },
  "bin": {
    "dial": "./dist/cli.js"
  },
  "preferGlobal": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "skills.tar.gz",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p .",
    "test": "node --import tsx --test",
    "clean": "rm -rf dist skills.tar.gz",
    "build:skill": "tar -czf skills.tar.gz skills",
    "prepack": "npm run build && npm run build:skill"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pubnub": "^11.0.1",
    "undici": "^8.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "react-native-url-polyfill": "npm:empty-npm-package@1.0.0"
  }
}
